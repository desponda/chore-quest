datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  familyName String
  parentPin  String   @default("1234")
  createdAt  DateTime @default(now())
  children   Child[]
  quests     Quest[]
  rewards    Reward[]
}

model Child {
  id          String    @id @default(cuid())
  userId      String
  name        String
  avatar      String
  color       String
  credits     Int       @default(0)
  streak      Int       @default(0)
  lastActive  DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
  assignments QuestAssignment[]
  redemptions Redemption[]
}

model Quest {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  emoji       String
  credits     Int
  difficulty  String
  isGrabbable Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  assignments QuestAssignment[]
}

model QuestAssignment {
  id          String    @id @default(cuid())
  questId     String
  childId     String
  status      String    @default("available")
  completedAt DateTime?
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
  quest       Quest     @relation(fields: [questId], references: [id])
  child       Child     @relation(fields: [childId], references: [id])
}

model Reward {
  id          String       @id @default(cuid())
  userId      String
  title       String
  description String
  emoji       String
  cost        Int
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  user        User         @relation(fields: [userId], references: [id])
  redemptions Redemption[]
}

model Redemption {
  id        String   @id @default(cuid())
  rewardId  String
  childId   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  reward    Reward   @relation(fields: [rewardId], references: [id])
  child     Child    @relation(fields: [childId], references: [id])
}
